{
  "$schema": "https://biomejs.dev/schemas/2.4.7/schema.json",
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": { "noUnusedVariables": "warn" },
      "style": { "useImportType": "on", "useConst": "error" }
    }
  },
  "formatter": { "enabled": false },
  "files": {
    "includes": [
      "**",
      "!**/dist",
      "!**/node_modules",
      "!**/bun.lock",
      "!**/*.config.js",
      "!**/*.config.ts"
    ]
  }
}
