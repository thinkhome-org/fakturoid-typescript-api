{
  "name": "@thinkhome-org/fakturoid-typescript-api",
  "version": "0.1.3",
  "description": "Backend Fakturoid SDK v TypeScriptu připravené pro multi-tenant integraci a Convex.",
  "packageManager": "bun@1.3.5",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/thinkhome-org/fakturoid-typescript-api.git"
  },
  "bugs": {
    "url": "https://github.com/thinkhome-org/fakturoid-typescript-api/issues"
  },
  "homepage": "https://github.com/thinkhome-org/fakturoid-typescript-api#readme",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "bunx tsc -p tsconfig.json",
    "lint": "bunx @biomejs/biome check .",
    "lint:fix": "bunx @biomejs/biome check --write .",
    "format": "bunx prettier --write .",
    "format:check": "bunx prettier --check .",
    "typecheck": "bunx tsc -p tsconfig.json --noEmit",
    "test": "bun test"
  },
  "keywords": [
    "fakturoid",
    "sdk",
    "typescript",
    "oauth2"
  ],
  "author": "",
  "license": "Apache-2.0",
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "bun-types": "^1.3.10",
    "prettier": "^3.8.1",
    "typescript": "^5.7.0"
  }
}
